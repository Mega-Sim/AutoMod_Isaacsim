#usda 1.0
(
    defaultPrim = "Asset"
    metersPerUnit = 1
    upAxis = "Z"
)

def Xform "Asset"
{
    custom bool isaacsim:placeholder = true
    custom string isaacsim:stationType = "vehicle_home"

    def Sphere "Body"
    {
        double radius = 0.3
        float3 xformOp:translate = (0, 0, 0.3)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        color3f[] primvars:displayColor = [(0.95, 0.95, 0.95)] (
            interpolation = "constant"
        )
    }
}
